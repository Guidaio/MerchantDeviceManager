@model IEnumerable<MerchantDeviceManager.Web.Models.MerchantListModel>
@using MerchantDeviceManager.Domain.Entities
@{
    ViewData["Title"] = "Select Merchant";
}

<h1>Select Merchant & Role</h1>
<p class="text-muted">Choose a merchant and your role. Admin: full access; Support: create/view; Viewer: read-only.</p>

<div class="row mt-4">
    @foreach (var m in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@m.Name</h5>
                    <p class="card-text text-muted">@m.Document — @m.Status</p>
                    <form asp-action="Select" method="post" class="d-inline">
                        <input type="hidden" name="merchantId" value="@m.Id" />
                        <div class="mb-2">
                            <label for="role-@m.Id" class="form-label">Role</label>
                            <select name="role" id="role-@m.Id" class="form-select form-select-sm" style="max-width: 150px;">
                                <option value="Admin">Admin</option>
                                <option value="Support">Support</option>
                                <option value="Viewer">Viewer</option>
                            </select>
                        </div>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">Select & Manage Devices</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-warning">No merchants found. Run the application to seed demo data.</p>
}
