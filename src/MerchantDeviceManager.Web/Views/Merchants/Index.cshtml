@model IEnumerable<MerchantDeviceManager.Web.Models.MerchantListModel>
@{
    ViewData["Title"] = "Select Merchant";
}

<h1>Select Merchant (Tenant)</h1>
<p class="text-muted">Choose a merchant to manage its devices. Multi-tenant: each operator sees only their merchant's data.</p>

<div class="row mt-4">
    @foreach (var m in Model)
    {
        <div class="col-md-6 mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@m.Name</h5>
                    <p class="card-text text-muted">@m.Document — @m.Status</p>
                    <form asp-action="Select" method="post" class="d-inline">
                        <input type="hidden" name="merchantId" value="@m.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">Select & Manage Devices</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-warning">No merchants found. Run the application to seed demo data.</p>
}
